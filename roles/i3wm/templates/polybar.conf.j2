[colors]
bg       = #1a2332
fg       = #a4b1cd
green    = #c5f467
cyan     = #2ee7b6
red      = #ff3e3e
dim      = #313f55
white    = #ffffff

[bar/main]
monitor               =
width                 = 100%
height                = 44
offset-x              = 0
offset-y              = 0
radius                = 0
fixed-center          = true
bottom                = false

background            = ${colors.bg}
foreground            = ${colors.fg}

line-size             = 2
line-color            = ${colors.green}

border-size           = 0
padding-left          = 2
padding-right         = 2
module-margin-left    = 1
module-margin-right   = 1

font-0                = Hack:pixelsize=16;4
font-1                = Font Awesome 6 Free:style=Solid:pixelsize=16;4
font-2                = Font Awesome 6 Brands:pixelsize=16;4

modules-left          = i3
modules-center        = date
modules-right         = ip cpu memory tray

tray-position         = right
tray-padding          = 4
tray-maxsize          = 20
tray-background       = ${colors.bg}

separator             = %{F#313f55}│%{F-}
wm-restack            = i3
override-redirect     = false
enable-ipc            = true

cursor-click          = pointer
cursor-scroll         = ns-resize

[module/i3]
type                  = internal/i3
format                = <label-state> <label-mode>
index-sort            = true
wrapping-scroll       = false

label-focused         = %index%
label-focused-foreground = ${colors.green}
label-focused-background = ${colors.dim}
label-focused-underline  = ${colors.green}
label-focused-padding    = 2

label-unfocused         = %index%
label-unfocused-foreground = ${colors.fg}
label-unfocused-padding    = 2

label-urgent            = %index%
label-urgent-foreground = ${colors.red}
label-urgent-padding    = 3

[module/date]
type                  = internal/date
interval              = 1
date                  = %a %d %b
time                  = %H:%M:%S
format-prefix         = " "
format-prefix-foreground = ${colors.cyan}
label                 = %date%  %time%
label-foreground      = ${colors.fg}

[module/ip]
type                  = custom/script
exec                  = ip route get 1.1.1.1 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1)}' || echo "no-ip"
interval              = 10
format-prefix         = " "
format-prefix-foreground = ${colors.green}
label                 = %output%
label-foreground      = ${colors.fg}

[module/cpu]
type                  = internal/cpu
interval              = 2
format-prefix         = " "
format-prefix-foreground = ${colors.cyan}
label                 = %percentage%%
label-foreground      = ${colors.fg}

[module/memory]
type                  = internal/memory
interval              = 2
format-prefix         = " "
format-prefix-foreground = ${colors.cyan}
label                 = %percentage_used%%
label-foreground      = ${colors.fg}

[module/tray]
type                  = internal/tray
icon-size             = 20
icon-padding          = 4

[settings]
screenchange-reload   = true
pseudo-transparency   = false
