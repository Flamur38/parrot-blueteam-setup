# === Shadows ===
shadow = false;

# === Fading ===
fading = true;
fade-in-step  = 0.05;
fade-out-step = 0.05;
fade-delta    = 5;

# === Opacity ===
inactive-opacity         = 0.92;
active-opacity           = 1.0;
frame-opacity            = 1.0;
inactive-opacity-override = false;

# === Corners ===
corner-radius = 6;

# === Backend ===
backend = "glx";
vsync   = true;
