* {
  bg:       #1a2332;
  fg:       #a4b1cd;
  green:    #c5f467;
  dim:      #313f55;
  red:      #ff3e3e;

  background-color: transparent;
  text-color:       @fg;
  font:             "Hack 19";
}

window {
  background-color: @bg;
  border:           2px;
  border-color:     @green;
  border-radius:    6px;
  width:            1100px;
  padding:          16px;
}

mainbox {
  background-color: transparent;
  children:         [ inputbar, listview ];
  spacing:          12px;
}

inputbar {
  background-color: @dim;
  border-radius:    4px;
  padding:          12px 16px;
  children:         [ prompt, entry ];
}

prompt {
  text-color:       @green;
  padding:          0 8px 0 0;
}

entry {
  text-color:       @fg;
  placeholder:      "search...";
  placeholder-color: #646464;
}

listview {
  background-color: transparent;
  lines:            10;
  scrollbar:        false;
  spacing:          4px;
}

element {
  background-color: transparent;
  border-radius:    4px;
  padding:          10px 16px;
}

element selected {
  background-color: @dim;
  text-color:       @green;
}

element-icon {
  size:    24px;
  padding: 0 10px 0 0;
}

element-text {
  font: "Hack 18";
}
