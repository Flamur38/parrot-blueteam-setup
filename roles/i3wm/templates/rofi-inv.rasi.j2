* {
  bg:    #0a0a0a;
  fg:    #646464;
  red:   #b42828;
  dim:   #1a1a1a;

  background-color: transparent;
  text-color:       @fg;
  font:             "Hack 19";
}

window {
  background-color: @bg;
  border:           1px;
  border-color:     @red;
  border-radius:    0px;
  width:            1100px;
  padding:          16px;
}

mainbox {
  background-color: transparent;
  children:         [ inputbar, listview ];
  spacing:          12px;
}

inputbar {
  background-color: @dim;
  border-radius:    0px;
  padding:          12px 16px;
  children:         [ prompt, entry ];
}

prompt {
  text-color:       @red;
  padding:          0 8px 0 0;
}

entry {
  text-color:       @fg;
  placeholder:      "search...";
  placeholder-color: #3a3a3a;
}

listview {
  background-color: transparent;
  lines:            10;
  scrollbar:        false;
  spacing:          4px;
}

element {
  background-color: transparent;
  border-radius:    0px;
  padding:          10px 16px;
}

element selected {
  background-color: @dim;
  text-color:       @red;
}

element-icon {
  size:    24px;
  padding: 0 10px 0 0;
}

element-text {
  font: "Hack 18";
}
