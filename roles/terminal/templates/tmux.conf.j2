# === Investigation mode — uncomment to switch ===
set -g status-position bottom
set -g status-style          "bg=#0a0a0a,fg=#646464"
set -g status-left-length    40
set -g status-right-length   80
set -g status-left           "#[fg=#b42828,bold] inv #[fg=#3a3a3a]│#[fg=#646464] #S  "
set -g status-right          "#[fg=#3a3a3a]│#[fg=#646464] %H:%M #[fg=#3a3a3a]│#[fg=#b42828] #H "
set -g window-status-format         "#[fg=#3a3a3a]  #I:#W  "
set -g window-status-current-format "#[fg=#b42828,bold]  #I:#W  "
set -g window-status-separator      ""
set -g pane-border-style        "fg=#1a1a1a"
set -g pane-active-border-style "fg=#b42828"
set -g message-style            "bg=#0a0a0a,fg=#b42828"

# === Plugins ===
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-logging'
set -g @plugin 'tmux-plugins/tmux-yank'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-copycat'

set -g @logging-key "P"
set -g @logging-key-end "L"
set -g @logging-path "~/tmux_logs/"

run '~/.tmux/plugins/tpm/tpm'
